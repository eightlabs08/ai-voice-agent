# =============================================================================
# AI Voice Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are required unless marked (optional).

# -- Vapi (Voice AI Orchestrator) ---------------------------------------------
# Get your API key from https://dashboard.vapi.ai
VAPI_API_KEY=
# The Vapi phone number ID to use for outbound test calls
VAPI_PHONE_NUMBER_ID=

# -- Twilio (SMS Notifications) -----------------------------------------------
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number in E.164 format, e.g. +15551234567
TWILIO_PHONE_NUMBER=

# -- LLM Provider -------------------------------------------------------------
# Configure at least one. The assistant defaults to Claude (Anthropic).
# Get key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Get key from https://platform.openai.com (also used for embeddings)
OPENAI_API_KEY=

# -- ElevenLabs (Text-to-Speech) ----------------------------------------------
# Configured in the Vapi dashboard. Only needed if using the Vapi API to
# set TTS credentials programmatically.
ELEVENLABS_API_KEY=

# -- Google Calendar -----------------------------------------------------------
# The calendar ID to check availability and book appointments.
# Usually looks like: your-email@gmail.com or a long string@group.calendar.google.com
GOOGLE_CALENDAR_ID=
# Base64-encoded JSON service account key.
# Encode it: cat service-account-key.json | base64 -w 0
GOOGLE_SERVICE_ACCOUNT_KEY=

# -- Pinecone (Vector Database for RAG) ---------------------------------------
# Get key from https://app.pinecone.io
PINECONE_API_KEY=
# Name of the Pinecone index to use (will be created by the seed script)
PINECONE_INDEX_NAME=ai-voice-agent

# -- HubSpot (CRM) ------------------------------------------------------------
# Private app access token from https://developers.hubspot.com
HUBSPOT_API_KEY=

# -- Resend (Email Notifications) ----------------------------------------------
# Get key from https://resend.com/api-keys
RESEND_API_KEY=
# Your verified domain email or use onboarding@resend.dev for testing
RESEND_FROM_EMAIL=onboarding@resend.dev

# -- n8n (Workflow Automation) ------------------------------------------------
# (optional) Webhook URL for triggering post-call workflows
N8N_WEBHOOK_URL=

# -- Server --------------------------------------------------------------------
PORT=3001
